{
  "expo": {
    "name": "Shelfy",
    "slug": "shelfy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/shelfy-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/shelfy-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.joinshelfy.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/natively-dark.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "zenspace",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://fpwfyjyxhxm8g8jq7ja97z9paejacdzq.app.specular.dev"
    }
  }
}
